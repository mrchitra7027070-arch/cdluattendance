# MongoDB Connection Configuration
# 1. Get your connection string from MongoDB Atlas
# 2. Whitelist your IP address in Atlas (or add 0.0.0.0/0 for testing)
# 3. If you see 'ECONNREFUSED' locally, try the older connection string format (without +srv)
MONGODB_URI=

# Port (Default is 3000)
PORT=3000

# Frontend static hosting
# Use this when the React app is hosted separately from the API, for example on GitHub Pages.
# Example: VITE_API_BASE_URL=https://your-backend.onrender.com
VITE_API_BASE_URL=

# Optional. The GitHub Pages workflow sets this automatically.
VITE_GITHUB_PAGES=false

# Optional backend CORS control. Use your GitHub Pages URL in production, or leave "*" for testing.
# Example: CORS_ORIGIN=https://your-username.github.io
CORS_ORIGIN=*
